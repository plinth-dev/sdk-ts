{
  "name": "@plinth-dev/authz-react",
  "version": "0.1.0",
  "description": "React permissions library — PermissionsProvider, usePermissions, Can/CanAny/CanAll. Consumes a permission map from sdk-ts/authz; never calls Cerbos itself.",
  "license": "MIT",
  "homepage": "https://plinth.run/sdk/ts/authz-react/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plinth-dev/sdk-ts.git",
    "directory": "packages/authz-react"
  },
  "bugs": {
    "url": "https://github.com/plinth-dev/sdk-ts/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "happy-dom": "^15.11.7",
    "react": "^19.0.0",
    "tsup": "^8.4.1",
    "typescript": "^5.9.0",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
